# GTM 環境変数サンプル
# 開発中は何も設定しなくても MOCK_MODE で全機能が動きます。

# モックモード（true=外部API不要でモック動作 / false=実API接続）※最終フェーズまで true
MOCK_MODE=true

# 既定の市場（JP または GLOBAL）
MARKET_DEFAULT=JP

# セッション署名用の秘密鍵（cookie改ざん防止）。本番は必ずランダムな長い文字列を設定
# 例: openssl rand -base64 32 で生成
AUTH_SECRET=

# ---- 外部データ/LLM/検証（最終フェーズで設定・それまで空でOK）----
# LLM_API_KEY=
# DATASOURCE_MAPS_API_KEY=
# DATASOURCE_JOBS_API_KEY=
# VERIFY_EMAIL_API_KEY=
# VERIFY_PHONE_API_KEY=

# ---- Stripe（コードは実装済み。鍵はクライアントが最後に設定）----
# STRIPE_SECRET_KEY=            # sk_test_... / sk_live_...
# STRIPE_WEBHOOK_SECRET=        # whsec_...（Webhook署名検証）
# STRIPE_PRICE_STARTER=         # price_...（Starterプランの価格ID）
# STRIPE_PRICE_PRO=             # price_...（Proプランの価格ID）
# STRIPE_PRICE_SCALE=           # price_...（Scaleプランの価格ID）

# ---- DB（クライアント用意の開発環境に接続。本番には触れない）----
# DATABASE_URL=                 # 例: postgresql://user:pass@host:5432/dbname?schema=public
# DIRECT_URL=                   # （任意）マイグレーション用の直結URL
